    :root {
      --bg: #141414; --card: #1a1a1a; --accent: #e50914;
      --text: #fff; --muted: #b3b3b3; --border: rgba(255,255,255,0.08);
      --font-title: 'Bebas Neue', sans-serif;
      --font-body: 'DM Sans', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: var(--font-body); font-size: 15px; line-height: 1.7; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    header {
      background: rgba(20,20,20,0.97);
      border-bottom: 1px solid var(--border);
      padding: 0 5%;
      height: 60px; display: flex; align-items: center;
      position: sticky; top: 0; z-index: 10;
    }
    .logo { font-family: var(--font-title); font-size: 24px; color: var(--accent); }
    .logo em { color: #fff; font-style: normal; }
    header nav a { color: var(--muted); font-size: 13px; margin-left: 20px; }
    header nav a:hover { color: #fff; }

    .page-hero {
      background: linear-gradient(to bottom, #1a1a1a, var(--bg));
      padding: 60px 5% 40px;
      border-bottom: 1px solid var(--border);
    }
    .page-hero h1 { font-family: var(--font-title); font-size: clamp(28px, 5vw, 52px); letter-spacing: 3px; margin-bottom: 8px; }
    .page-hero h1 span { color: var(--accent); }
    .page-hero p { color: var(--muted); font-size: 14px; }

    .container { max-width: 820px; margin: 0 auto; padding: 48px 5% 80px; }

    .legal-block {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 32px;
      margin-bottom: 20px;
    }
    .legal-block h2 {
      font-family: var(--font-title); font-size: 22px; letter-spacing: 2px;
      color: var(--accent); margin-bottom: 16px;
      padding-bottom: 10px; border-bottom: 1px solid var(--border);
    }
    .legal-block p { color: var(--muted); margin-bottom: 10px; }
    .legal-block p:last-child { margin-bottom: 0; }
    .legal-block strong { color: var(--text); }

    .info-table {
      width: 100%; border-collapse: collapse; margin-top: 12px; font-size: 14px;
    }
    .info-table th {
      text-align: left; padding: 10px 14px;
      background: rgba(255,255,255,0.04);
      color: var(--muted); font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
      border-bottom: 1px solid var(--border);
    }
    .info-table td {
      padding: 10px 14px; color: var(--muted);
      border-bottom: 1px solid rgba(255,255,255,0.04);
      vertical-align: top;
    }
    .info-table td:first-child { color: var(--text); font-weight: 600; width: 35%; }

    .rights-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 12px; margin-top: 12px;
    }
    .right-item {
      background: rgba(229,9,20,0.08);
      border: 1px solid rgba(229,9,20,0.2);
      border-radius: 6px; padding: 14px;
    }
    .right-item strong { display: block; color: var(--text); margin-bottom: 4px; font-size: 14px; }
    .right-item span { color: var(--muted); font-size: 13px; }

    footer {
      border-top: 1px solid var(--border);
      padding: 24px 5%; text-align: center; font-size: 12px; color: #555;
    }
    footer a { color: var(--accent); }

    @media (max-width: 480px) {
      .rights-grid { grid-template-columns: 1fr; }
      .info-table td:first-child { width: 40%; }
    }
  </style>
</head>
